# Normalize line endings. Repo is developed on Windows but runs in Linux
# containers — force LF for everything that executes or is parsed there.
* text=auto eol=lf

# Explicit LF for container-critical and code files
*.py    text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
Dockerfile text eol=lf
.env.example text eol=lf

# Binary (don't touch)
*.docx  binary
*.png   binary
*.jpg   binary
