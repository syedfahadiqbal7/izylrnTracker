<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>
<properties>

    <!-- ====================================================================
         IzySafe Traccar configuration (dev)
         Mounted read-only at /opt/traccar/conf/traccar.xml
         ====================================================================
         CRITICAL: Traccar uses the shared PostgreSQL instance (database
         `traccar`), NOT its default H2 in-memory database. Traccar creates and
         migrates its own schema there via Liquibase on first start.
         ==================================================================== -->

    <!-- Inherit all of Traccar's built-in defaults (protocol ports, etc.) -->
    <entry key='config.default'>./conf/default.xml</entry>

    <!-- Database: shared PostgreSQL, separate `traccar` DB -->
    <entry key='database.driver'>org.postgresql.Driver</entry>
    <entry key='database.url'>jdbc:postgresql://postgres:5432/traccar</entry>
    <entry key='database.user'>izysafe</entry>
    <!-- Must match POSTGRES_PASSWORD in .env -->
    <entry key='database.password'>change_me_dev_password</entry>

    <!-- Web UI -->
    <entry key='web.port'>8082</entry>

    <!-- ====================================================================
         POSITION FORWARDING → IzySafe backend webhook
         Every decoded position is POSTed as JSON to our FastAPI webhook.
         The shared secret header is validated by the backend (dev). In prod
         this is upgraded to a true HMAC signature (see CLAUDE.md §7).
         ==================================================================== -->
    <entry key='forward.enable'>true</entry>
    <entry key='forward.url'>http://backend:8000/api/v1/webhook/traccar</entry>
    <entry key='forward.type'>json</entry>
    <entry key='forward.header'>X-Traccar-Secret: change_me_webhook_secret</entry>

    <!-- ====================================================================
         EVENT FORWARDING → IzySafe alarm webhook
         SOS / alarm events are delivered here (separate from positions).
         ==================================================================== -->
    <entry key='event.forward.enable'>true</entry>
    <entry key='event.forward.url'>http://backend:8000/api/v1/webhook/traccar/alarm</entry>
    <entry key='event.forward.header'>X-Traccar-Secret: change_me_webhook_secret</entry>

    <!-- Protocol ports (also provided by default.xml; listed for clarity):
         GT06 = 5023 (primary, ~70% of affordable 4G kids watches),
         TK103 = 5002, H02 = 5013. These are exposed in docker-compose. -->

</properties>
