# ============================================================================
# IzySafe — PRODUCTION environment (TEMPLATE)
# Copy to .env and fill REAL values:   cp .env.production.example .env
# .env is gitignored. NEVER commit real secrets. Restrict file perms: chmod 600 .env
#
# Generate strong secrets:
#   openssl rand -hex 32       → JWT_SECRET, TRACCAR_WEBHOOK_SECRET
#   openssl rand -base64 30    → POSTGRES_PASSWORD, TRACCAR_API_PASSWORD
# ============================================================================

# ---- Environment ----
ENVIRONMENT=production
# Singleton lifespan loops (batch writer + device-status monitor). Keep TRUE on
# exactly one backend instance; set false on any extra web replicas (see DEPLOY.md).
RUN_BACKGROUND_LOOPS=true

# ---- PostgreSQL ----
# POSTGRES_PASSWORD must match the password in DATABASE_URL below AND in traccar/traccar.xml.
POSTGRES_DB=izysafe
POSTGRES_USER=izysafe
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password
DATABASE_URL=postgresql+asyncpg://izysafe:__CHANGE_ME__strong_db_password@postgres:5432/izysafe

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Auth / JWT ----
JWT_SECRET=__CHANGE_ME__openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=1440      # 24h
JWT_REFRESH_EXPIRE_DAYS=30

# ---- CORS ----
# The admin panel is served same-origin (nginx proxies /api), so it needs no CORS
# entry. List any OTHER trusted browser origins that call the API directly.
ALLOWED_ORIGINS=https://panel.yourdomain.com

# ---- Traccar (GPS middleware) ----
TRACCAR_URL=http://traccar:8082
TRACCAR_API_USER=admin@yourdomain.com
TRACCAR_API_PASSWORD=__CHANGE_ME__traccar_admin_password
# Must match the X-Traccar-Secret header in traccar/traccar.xml.
TRACCAR_WEBHOOK_SECRET=__CHANGE_ME__openssl_rand_hex_32

# ---- Firebase (Realtime DB live location + FCM push) ----
# Path INSIDE the backend container; the file is bind-mounted from ./backend/secrets.
FIREBASE_CREDENTIALS_JSON=/app/secrets/firebase-service-account.json
FIREBASE_DATABASE_URL=https://izysafe-prod-default-rtdb.<region>.firebasedatabase.app

# ---- OTP delivery (WhatsApp/SMS) ----
MSG91_AUTH_KEY=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Payments ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Storage: Cloudflare R2 (child photos, weekly PDFs) ----
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=izysafe-prod
R2_ENDPOINT=

# ---- Google Maps (reverse geocoding) ----
GOOGLE_MAPS_API_KEY=

# ---- App ----
BACKEND_URL=https://panel.yourdomain.com
