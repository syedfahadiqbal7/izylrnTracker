# ============================================================================
# IzySafe — Environment Variables (TEMPLATE)
# Copy to .env and fill real values:  cp .env.example .env
# .env is gitignored. NEVER commit real secrets.
# ============================================================================
# Generate strong secrets with:
#   openssl rand -hex 32        (JWT_SECRET, TRACCAR_WEBHOOK_SECRET)
#   openssl rand -base64 24     (passwords)
# ============================================================================

# ---- Environment ----
ENVIRONMENT=development          # development | staging | production

# ---- PostgreSQL ----
# POSTGRES_PASSWORD is consumed by the postgres container AND must match the
# password embedded in DATABASE_URL below and in traccar/traccar.xml.
POSTGRES_DB=izysafe
POSTGRES_USER=izysafe
POSTGRES_PASSWORD=change_me_dev_password

# App DB connection (async driver). Host = compose service name `postgres`.
DATABASE_URL=postgresql+asyncpg://izysafe:change_me_dev_password@postgres:5432/izysafe

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Firebase (real DEV project, Blaze plan — no emulator) ----
# Path INSIDE the backend container where the service-account JSON is mounted.
FIREBASE_CREDENTIALS_JSON=/app/secrets/firebase-service-account.json
FIREBASE_DATABASE_URL=https://izysafe-dev-default-rtdb.asia-southeast1.firebasedatabase.app

# ---- Traccar ----
TRACCAR_URL=http://traccar:8082
# Create the admin account on first Traccar web login, then put it here.
TRACCAR_API_USER=admin@izysafe.local
TRACCAR_API_PASSWORD=change_me_traccar_admin
# Must match the X-Traccar-Secret header value in traccar/traccar.xml.
TRACCAR_WEBHOOK_SECRET=change_me_webhook_secret

# ---- Auth / JWT ----
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=1440      # 24h
JWT_REFRESH_EXPIRE_DAYS=30

# ---- OTP delivery (Sprint 1) ----
MSG91_AUTH_KEY=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Payments (Sprint 6) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Storage: Cloudflare R2 (Sprint 1 photos / Sprint 8 PDFs) ----
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=izysafe-dev
R2_ENDPOINT=

# ---- Google Maps ----
GOOGLE_MAPS_API_KEY=

# ---- App ----
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Public base for Share Link tracking pages ({base}/{token}). Dev = the backend's own
# /track path; in prod set this to https://<panel-host>/track (nginx proxies /track/).
SHARE_LINK_BASE_URL=http://localhost:8000/track
